        End If
NextRP4:
    Next r

    For g = 1 To gc4
        If oc >= MAXG Then GoTo SkipP4
        oc = oc + 1
        Dim st4 As String : Dim n4 As String
        st4 = IIf(g4Rows(g)=1, "SINGLE-SIDED", "TRUE BREAK")
        If st4 = "TRUE BREAK" Then
            n4 = "Open qty: " & Format(g4NetQ(g),"+0.###;-0.###")
            If Abs(g4NetV(g)) >= 0.01 Then
                n4 = n4 & " | Net value: " & Format(g4NetV(g),"+#,##0.00;-#,##0.00")
            End If
            If Not g4HasHO(g) Then n4 = n4 & " | No H/O cancel side."
            If Not g4HasDK(g) Then n4 = n4 & " | No DK add side."
            If InStr(g4Dates(g),",")>0 Then n4 = n4 & " | Dates: " & g4Dates(g)
        Else
            n4 = "Single row — nothing to net against."
        End If
        oLabel(oc)=st4:oNote(oc)=n4:oGMI(oc)=g4GMI(g):oProd(oc)=g4Prod(g)
        oDates(oc)=g4Dates(g):oPrice(oc)=g4Price(g):oNetQty(oc)=g4NetQ(g)
        oNetVal(oc)=g4NetV(g):oMembers(oc)=g4Mem(g):oSec(oc)=g4Sec(g)
        oIsMixed(oc) = False
        Call CountStat(st4,cFB,cAPS,cPB,cTB,cSS)
SkipP4:
    Next g

    ' ════════════════════════════════════════════════════════════
    ' WRITE OUTPUT
    ' ════════════════════════════════════════════════════════════
    With wsOut
        If .AutoFilterMode Then .AutoFilterMode = False
        .Range("A7:N6000").ClearContents
        .Range("A7:N6000").Interior.ColorIndex = xlNone
        .Range("A7:N6000").Borders.LineStyle = xlNone
    End With

    Dim outR As Long : outR = 7

    ' Write FALSE BREAKs first, then others, then NEEDS REVIEW last
    Dim sortOrder(6) As String
    sortOrder(1)="FALSE BREAK":sortOrder(2)="APS ROUNDING"
    sortOrder(3)="PRICE BREAK":sortOrder(4)="TRUE BREAK"
    sortOrder(5)="SINGLE-SIDED":sortOrder(6)="NEEDS REVIEW"

    Dim so As Long
    For so = 1 To 6
        Dim oi As Long
        For oi = 1 To oc
            If oLabel(oi)<>sortOrder(so) Then GoTo NextOI
            If oIsMixed(oi) Then
                If sortOrder(so) <> "NEEDS REVIEW" Then GoTo NextOI
                Call WriteMixedGroup(wsOut, outR, oNote(oi), oGMI(oi), oProd(oi), _
                    oDates(oi), oPrice(oi), oHoQty(oi), oHoVal(oi), _
                    oDkQty(oi), oDkVal(oi), oHoMem(oi), oDkMem(oi), _
                    oSec(oi), rData, rRawQty)
                oHoMem(oi) = "" : oDkMem(oi) = ""
            Else
                If oMembers(oi)="" Then GoTo NextOI
                Call WriteGroup(wsOut, outR, oLabel(oi), oNote(oi), _
                                oGMI(oi), oProd(oi), oDates(oi), oPrice(oi), _
                                oNetQty(oi), oNetVal(oi), oMembers(oi), oSec(oi), rData)
                oMembers(oi) = ""
            End If
NextOI:
        Next oi
    Next so

    ' ── Stats ────────────────────────────────────────────────────
    wsOut.Cells(4,1).Value  = "Total Rows:  " & rc
    wsOut.Cells(4,3).Value  = "Break Groups:  " & (cFB+cAPS+cPB+cTB+cSS)
    wsOut.Cells(4,5).Value  = "False Breaks:  " & cFB & IIf(cAPS>0," (+" & cAPS & " APS)","")
    wsOut.Cells(4,7).Value  = "Price Breaks:  " & cPB
    wsOut.Cells(4,9).Value  = "True Breaks:  " & cTB & " (incl. mixed groups)"
    wsOut.Cells(4,11).Value = "Single-Sided:  " & cSS

    With wsOut.Cells(4,1):.Font.Bold=True:.Font.Size=10:.Font.Name="Calibri":.Font.Color=RGB(0,0,0):End With
    With wsOut.Cells(4,3):.Font.Bold=True:.Font.Size=10:.Font.Name="Calibri":.Font.Color=RGB(0,0,0):End With
    With wsOut.Cells(4,5):.Font.Bold=True:.Font.Size=10:.Font.Name="Calibri":.Font.Color=RGB(55,86,35):.Interior.Color=RGB(226,239,218):End With
    With wsOut.Cells(4,7):.Font.Bold=True:.Font.Size=10:.Font.Name="Calibri":.Font.Color=RGB(31,73,125):.Interior.Color=RGB(221,238,255):End With
    With wsOut.Cells(4,9):.Font.Bold=True:.Font.Size=10:.Font.Name="Calibri":.Font.Color=RGB(132,60,12):.Interior.Color=RGB(252,228,214):End With
    With wsOut.Cells(4,11):.Font.Bold=True:.Font.Size=10:.Font.Name="Calibri":.Font.Color=RGB(89,89,89):.Interior.Color=RGB(237,237,237):End With

    wsOut.Range("A6:N6").AutoFilter
    wsOut.Activate
    wsOut.Cells(7,1).Select

    MsgBox "Done!" & Chr(10) & Chr(10) & _
           rc & " rows processed" & Chr(10) & _
           "False Breaks:   " & cFB & Chr(10) & _
           "APS Rounding:   " & cAPS & Chr(10) & _
           "Price Breaks:   " & cPB & Chr(10) & _
           "True Breaks:    " & cTB & " (incl. mixed groups)" & Chr(10) & _
           "Single-Sided:   " & cSS, vbInformation, "Recon Complete"

Cleanup:
    Application.ScreenUpdating = True
    Application.Calculation = xlCalculationAutomatic
End Sub

' ════════════════════════════════════════════════════════════════════
Public Sub ClearResults()
    Dim wsOut As Worksheet
    Set wsOut = ThisWorkbook.Sheets("RESULTS")
    With wsOut
        If .AutoFilterMode Then .AutoFilterMode = False
        .Range("A7:N6000").ClearContents
        .Range("A7:N6000").Interior.ColorIndex = xlNone
        .Range("A7:N6000").Borders.LineStyle = xlNone
    End With
    wsOut.Cells(4,1).Value="Total Rows:":wsOut.Cells(4,3).Value="Break Groups:"
    wsOut.Cells(4,5).Value="False Breaks:":wsOut.Cells(4,7).Value="Price Breaks:"
    wsOut.Cells(4,9).Value="True Breaks:":wsOut.Cells(4,11).Value="Single-Sided:"
    MsgBox "Results cleared.", vbInformation, "Cleared"
End Sub
