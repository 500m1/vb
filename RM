Attribute VB_Name = "ReconMacro"
Option Explicit

Private Const APS_THRESHOLD As Double = 20.0

' ── Safe helpers ──────────────────────────────────────────────────
Private Function SafeDbl(v As Variant) As Double
    Dim s As String
    On Error Resume Next
    If IsEmpty(v) Or IsNull(v) Then SafeDbl = 0 : Exit Function
    s = Trim(CStr(v))
    s = Replace(s, "CAD", "") : s = Replace(s, "USD", "")
    s = Replace(s, "$", "") : s = Replace(s, ",", "") : s = Replace(s, " ", "")
    If Left(s, 1) = "(" And Right(s, 1) = ")" Then
        s = "-" & Mid(s, 2, Len(s) - 2)
    End If
    If s = "" Or s = "-" Then SafeDbl = 0 : Exit Function
    If IsNumeric(s) Then SafeDbl = CDbl(s) Else SafeDbl = 0
    On Error GoTo 0
End Function

Private Function SafeStr(v As Variant) As String
    On Error Resume Next
    If IsEmpty(v) Or IsNull(v) Then SafeStr = "" : Exit Function
    SafeStr = Trim(CStr(v))
    On Error GoTo 0
End Function

Private Function IsHO(hodk As String) As Boolean
    IsHO = (Left(UCase(Trim(hodk)), 1) = "H")
End Function

Private Function PriceKey(p As Double) As String
    PriceKey = Format(Round(p, 4), "0.0000")
End Function

Private Function IntPriceKey(p As Double) As String
    IntPriceKey = CStr(CLng(Int(Abs(p))))
End Function

Private Function IsHeaderRow(ws As Worksheet, rowNum As Long, _
                             ByRef secLabel As String) As Boolean
    Dim j As Long, full As String
    full = ""
    For j = 1 To 7
        full = full & " " & UCase(SafeStr(ws.Cells(rowNum, j).Value))
    Next j
    full = Trim(full)
    Dim kw(11) As String
    kw(0)="HOUSE":kw(1)="CUST":kw(2)="CUSTOMER":kw(3)="HSE"
    kw(4)="SUS":kw(5)="SUSPENSE":kw(6)="BREAKS":kw(7)="ADJUSTMENT"
    kw(8)="CANADIAN":kw(9)="BARCLAYS":kw(10)="GLOBAL":kw(11)="RBC"
    Dim k As Long
    For k = 0 To 11
        If InStr(full, kw(k)) > 0 Then
            If Len(full) > 2 Then secLabel = Trim(full)
            IsHeaderRow = True : Exit Function
        End If
    Next k
    Dim a As String : a = UCase(SafeStr(ws.Cells(rowNum, 1).Value))
    If a="GMI" Or a="DATE" Or a="QTY" Or a="MONTH" Or a="ACCOUNT" Then
        IsHeaderRow = True : Exit Function
    End If
    IsHeaderRow = False
End Function

Private Sub GetColors(st As String, bgC As Long, fgC As Long, bdC As Long)
    Select Case st
        Case "FALSE BREAK"
            bgC=RGB(226,239,218):fgC=RGB(55,86,35):bdC=RGB(112,173,71)
        Case "APS ROUNDING"
            bgC=RGB(235,245,220):fgC=RGB(55,86,35):bdC=RGB(150,200,100)
        Case "PRICE BREAK"
            bgC=RGB(221,238,255):fgC=RGB(31,73,125):bdC=RGB(46,117,182)
        Case "TRUE BREAK"
            bgC=RGB(252,228,214):fgC=RGB(132,60,12):bdC=RGB(192,80,77)
        Case Else
            bgC=RGB(237,237,237):fgC=RGB(89,89,89):bdC=RGB(128,128,128)
    End Select
End Sub

Private Sub ColorRow(wsOut As Worksheet, outR As Long, _
                     bgC As Long, fgC As Long, bdC As Long)
    Dim c As Long
    For c = 1 To 14
        With wsOut.Cells(outR, c)
            .Interior.Color = bgC : .Font.Color = fgC
            .Font.Bold = False : .Font.Size = 10 : .Font.Name = "Calibri"
            .VerticalAlignment = xlVAlignCenter
            .Borders(xlEdgeLeft).LineStyle   = xlContinuous
            .Borders(xlEdgeRight).LineStyle  = xlContinuous
            .Borders(xlEdgeTop).LineStyle    = xlContinuous
            .Borders(xlEdgeBottom).LineStyle = xlContinuous
            .Borders(xlEdgeLeft).Color  = bdC : .Borders(xlEdgeRight).Color = bdC
            .Borders(xlEdgeTop).Color   = bdC : .Borders(xlEdgeBottom).Color = bdC
            .Borders(xlEdgeLeft).Weight  = xlThin : .Borders(xlEdgeRight).Weight = xlThin
            .Borders(xlEdgeTop).Weight   = xlThin : .Borders(xlEdgeBottom).Weight = xlThin
        End With
    Next c
    wsOut.Rows(outR).RowHeight = 16
End Sub

Private Sub WriteGroup(wsOut As Worksheet, outR As Long, _
    st As String, note As String, _
    gmi As String, product As String, dates As String, price As Double, _
    netQty As Double, netVal As Double, _
    members As String, sec As String, rData() As String)

    Dim bgC As Long, fgC As Long, bdC As Long
    Call GetColors(st, bgC, fgC, bdC)

    Dim c As Long
    For c = 1 To 14
        wsOut.Cells(outR, c).Interior.Color = bdC
        wsOut.Cells(outR, c).Font.Color     = RGB(255,255,255)
        wsOut.Cells(outR, c).Font.Size      = 10
        wsOut.Cells(outR, c).Font.Name      = "Calibri"
        wsOut.Cells(outR, c).Font.Bold      = False
        wsOut.Cells(outR, c).Value          = ""
    Next c
    wsOut.Cells(outR,1).Value  = gmi : wsOut.Cells(outR,1).Font.Bold = True
    wsOut.Cells(outR,2).Value  = dates
    wsOut.Cells(outR,3).Value  = Format(netQty, "+0.###;-0.###;0")
    wsOut.Cells(outR,4).Value  = product
    wsOut.Cells(outR,5).Value  = Format(price, "0.0000")
    wsOut.Cells(outR,9).Value  = note
    wsOut.Cells(outR,9).WrapText = True : wsOut.Cells(outR,9).Font.Size = 9
    wsOut.Cells(outR,12).Value = Format(netVal, "+#,##0.00;-#,##0.00;0")
    wsOut.Cells(outR,13).Value = sec
    wsOut.Cells(outR,14).Value = st : wsOut.Cells(outR,14).Font.Bold = True
    wsOut.Cells(outR,14).HorizontalAlignment = xlHAlignCenter
    wsOut.Rows(outR).RowHeight = 18
    outR = outR + 1

    If members = "" Then GoTo DoneRows
    Dim parts() As String : parts = Split(members, "|")
    Dim p As Long
    For p = 0 To UBound(parts)
        If Trim(parts(p)) = "" Then GoTo NextP
        Dim ri As Long : ri = CLng(Trim(parts(p)))
        For c = 1 To 12
            wsOut.Cells(outR, c).Value = rData(ri, c)
        Next c
        Dim existAct As String : existAct = Trim(rData(ri, 9))
        wsOut.Cells(outR,9).Value = IIf(existAct="", st, existAct & " | " & st)
        wsOut.Cells(outR,13).Value = rData(ri, 13)
        wsOut.Cells(outR,14).Value = st
        Call ColorRow(wsOut, outR, bgC, fgC, bdC)
        outR = outR + 1
NextP:
    Next p
DoneRows:
    wsOut.Rows(outR).RowHeight = 5
    outR = outR + 1
End Sub

Private Sub CountStat(st As String, cFB As Long, cAPS As Long, _
                      cPB As Long, cTB As Long, cSS As Long)
    Select Case st
        Case "FALSE BREAK"  : cFB  = cFB  + 1
        Case "APS ROUNDING" : cAPS = cAPS + 1
        Case "PRICE BREAK"  : cPB  = cPB  + 1
        Case "TRUE BREAK"   : cTB  = cTB  + 1
        Case "SINGLE-SIDED" : cSS  = cSS  + 1
    End Select
End Sub

' ── Greedy subset matching within a mixed group ───────────────────
' Finds subsets of HO rows and DK rows that net to zero on qty AND value
' Returns pipe-delimited matched member indices and updates rMatched array
Private Sub MatchSubsets( _
    hoIdx() As Long, hoCount As Long, _
    dkIdx() As Long, dkCount As Long, _
    rEffQty() As Double, rEffVal() As Double, rRawQty() As Double, rRawVal() As Double, _
    rMatched() As Boolean, _
    oLabel() As String, oNote() As String, oGMI() As String, oProd() As String, _
    oDates() As String, oPrice() As Double, oNetQty() As Double, oNetVal() As Double, _
    oMembers() As String, oSec() As String, oc As Long, MAXG As Long, _
    gmi As String, prod As String, dt As String, px As Double, sec As String, _
    cFB As Long, cAPS As Long, cPB As Long, cTB As Long, cSS As Long)

    ' For each HO row, try to find DK rows whose abs qty sums to same abs qty
    ' and whose values net to zero
    Dim i As Long, j As Long
    Dim hoUsed(500) As Boolean
    Dim dkUsed(500) As Boolean

    For i = 1 To hoCount
        If hoUsed(i) Then GoTo NextHO
        Dim hoAQ As Double : hoAQ = Abs(rRawQty(hoIdx(i)))
        Dim hoAV As Double : hoAV = rRawVal(hoIdx(i))

        ' Try to find DK rows summing to same qty with matching value
        Dim dkSumQ As Double : dkSumQ = 0
        Dim dkSumV As Double : dkSumV = 0
        Dim matchList As String : matchList = ""
        Dim matchCount As Long : matchCount = 0

        ' Greedy: accumulate DK rows until qty matches
        For j = 1 To dkCount
            If dkUsed(j) Then GoTo NextDK
            If dkSumQ >= hoAQ - 0.001 Then GoTo NextDK  ' already reached target
            dkSumQ = dkSumQ + Abs(rRawQty(dkIdx(j)))
            dkSumV = dkSumV + rRawVal(dkIdx(j))
            matchList = IIf(matchList="", CStr(dkIdx(j)), matchList & "|" & CStr(dkIdx(j)))
            matchCount = matchCount + 1
NextDK:
        Next j

        ' Check if qty matches and value nets to zero
        If Abs(dkSumQ - hoAQ) < 0.001 And Abs(hoAV - dkSumV) < 0.01 Then
            ' Match found — mark as FALSE BREAK
            If oc < MAXG Then
                oc = oc + 1
                oLabel(oc) = "FALSE BREAK"
                oNote(oc)  = "Net qty = 0, net value = 0. Matched sub-group within mixed group."
                oGMI(oc)   = gmi : oProd(oc) = prod : oDates(oc) = dt
                oPrice(oc) = px  : oNetQty(oc) = 0 : oNetVal(oc) = 0
                oSec(oc)   = sec
                oMembers(oc) = CStr(hoIdx(i)) & "|" & matchList
                cFB = cFB + 1

                ' Mark all as used and matched
                hoUsed(i) = True
                rMatched(hoIdx(i)) = True
                Dim mParts() As String : mParts = Split(matchList, "|")
                Dim mp As Long
                For mp = 0 To UBound(mParts)
                    If Trim(mParts(mp)) <> "" Then
                        Dim mIdx As Long : mIdx = CLng(Trim(mParts(mp)))
                        rMatched(mIdx) = True
                        ' Mark dk as used
                        Dim jj As Long
                        For jj = 1 To dkCount
                            If dkIdx(jj) = mIdx Then dkUsed(jj) = True : Exit For
                        Next jj
                    End If
                Next mp
            End If
        Else
            ' No match for this HO row — reset and try next
            ' (DK rows not consumed since no match was found)
        End If
NextHO:
    Next i
End Sub

' ════════════════════════════════════════════════════════════════════
Public Sub RunRecon()
' ════════════════════════════════════════════════════════════════════

    Dim wsIn  As Worksheet
    Dim wsOut As Worksheet
    Set wsIn  = ThisWorkbook.Sheets("INPUT")
    Set wsOut = ThisWorkbook.Sheets("RESULTS")

    Application.ScreenUpdating = False
    Application.Calculation = xlCalculationManual

    Dim lastRow As Long
    lastRow = wsIn.Cells(wsIn.Rows.Count, 1).End(xlUp).Row
    If lastRow < 6 Then
        MsgBox "No data found in INPUT sheet.", vbExclamation
        GoTo Cleanup
    End If

    ' ── Read all rows ────────────────────────────────────────────
    Const MAXR As Long = 5000
    Dim rData(MAXR, 13)  As String
    Dim rEffQty(MAXR)    As Double
    Dim rEffVal(MAXR)    As Double
    Dim rRawQty(MAXR)    As Double
    Dim rRawVal(MAXR)    As Double
    Dim rIntPxKey(MAXR)  As String
    Dim rResolved(MAXR)  As Boolean
    Dim rMatched(MAXR)   As Boolean
    Dim rc As Long : rc = 0
    Dim curSec As String : curSec = ""

    Dim i As Long
    For i = 6 To lastRow
        Dim tmp As String : tmp = curSec
        If IsHeaderRow(wsIn, i, tmp) Then curSec = tmp : GoTo NextRIn
        Dim gv As String : gv = SafeStr(wsIn.Cells(i, 1).Value)
        If gv = "" Then GoTo NextRIn
        If rc >= MAXR Then GoTo NextRIn
        rc = rc + 1

        Dim col As Long
        For col = 1 To 12
            If col = 2 Then
                If IsDate(wsIn.Cells(i, col).Value) Then
                    rData(rc, col) = Format(CDate(wsIn.Cells(i, col).Value), "m/d/yyyy")
                Else
                    rData(rc, col) = SafeStr(wsIn.Cells(i, col).Value)
                End If
            Else
                rData(rc, col) = SafeStr(wsIn.Cells(i, col).Value)
            End If
        Next col
        rData(rc, 13) = curSec

        Dim ho As Boolean : ho = IsHO(rData(rc, 6))
        Dim q As Double : q = SafeDbl(rData(rc, 3))
        Dim v As Double : v = SafeDbl(rData(rc, 12))
        rRawQty(rc) = q : rRawVal(rc) = v
        If ho Then q = -q : v = -v
        rEffQty(rc)   = q
        rEffVal(rc)   = v
        rIntPxKey(rc) = IntPriceKey(SafeDbl(rData(rc, 5)))
        rResolved(rc) = False
        rMatched(rc)  = False
NextRIn:
    Next i

    If rc = 0 Then
        MsgBox "No valid data rows found.", vbExclamation
        GoTo Cleanup
    End If

    ' ════════════════════════════════════════════════════════════
    ' OUTPUT STORE
    ' ════════════════════════════════════════════════════════════
    Const MAXG As Long = 5000
    Dim oLabel(MAXG)   As String
    Dim oNote(MAXG)    As String
    Dim oGMI(MAXG)     As String
    Dim oProd(MAXG)    As String
    Dim oDates(MAXG)   As String
    Dim oPrice(MAXG)   As Double
    Dim oNetQty(MAXG)  As Double
    Dim oNetVal(MAXG)  As Double
    Dim oMembers(MAXG) As String
    Dim oSec(MAXG)     As String
    Dim oc As Long : oc = 0

    Dim cFB As Long, cAPS As Long, cPB As Long, cTB As Long, cSS As Long
    cFB=0:cAPS=0:cPB=0:cTB=0:cSS=0

    ' ════════════════════════════════════════════════════════════
    ' PASS 1 — GMI + Product + Date
    ' ════════════════════════════════════════════════════════════
    Const MAXG1 As Long = 3000
    Dim g1Key(MAXG1)     As String
    Dim g1GMI(MAXG1)     As String
    Dim g1Prod(MAXG1)    As String
    Dim g1Date(MAXG1)    As String
    Dim g1MinPx(MAXG1)   As Double
    Dim g1MaxPx(MAXG1)   As Double
    Dim g1PxList(MAXG1)  As String
    Dim g1NetQ(MAXG1)    As Double
    Dim g1NetV(MAXG1)    As Double
    Dim g1HOQty(MAXG1)   As Double
    Dim g1DKQty(MAXG1)   As Double
    Dim g1Rows(MAXG1)    As Long
    Dim g1HasHO(MAXG1)   As Boolean
    Dim g1HasDK(MAXG1)   As Boolean
    Dim g1Mem(MAXG1)     As String
    Dim g1Sec(MAXG1)     As String
    Dim gc1 As Long : gc1 = 0

    Dim r As Long
    For r = 1 To rc
        Dim k1 As String
        k1 = rData(r,1) & "||" & rData(r,4) & "||" & rData(r,2)
        Dim gi1 As Long : gi1 = 0
        Dim g As Long
        For g = 1 To gc1
            If g1Key(g) = k1 Then gi1 = g : Exit For
        Next g
        If gi1 = 0 Then
            If gc1 >= MAXG1 Then GoTo NextRP1
            gc1 = gc1 + 1 : gi1 = gc1
            g1Key(gi1)    = k1
            g1GMI(gi1)    = rData(r,1) : g1Prod(gi1) = rData(r,4)
            g1Date(gi1)   = rData(r,2)
            g1MinPx(gi1)  = SafeDbl(rData(r,5)) : g1MaxPx(gi1) = SafeDbl(rData(r,5))
            g1PxList(gi1) = PriceKey(SafeDbl(rData(r,5)))
            g1NetQ(gi1)   = 0 : g1NetV(gi1) = 0
            g1HOQty(gi1)  = 0 : g1DKQty(gi1) = 0
            g1Rows(gi1)   = 0
            g1HasHO(gi1)  = False : g1HasDK(gi1) = False
            g1Mem(gi1)    = "" : g1Sec(gi1) = ""
        End If
        Dim rp As Double : rp = SafeDbl(rData(r,5))
        If rp < g1MinPx(gi1) Then g1MinPx(gi1) = rp
        If rp > g1MaxPx(gi1) Then g1MaxPx(gi1) = rp
        Dim pkey As String : pkey = PriceKey(rp)
        If InStr(g1PxList(gi1), pkey) = 0 Then
            g1PxList(gi1) = g1PxList(gi1) & " | " & pkey
        End If
        g1NetQ(gi1) = g1NetQ(gi1) + rEffQty(r)
        g1NetV(gi1) = g1NetV(gi1) + rEffVal(r)
        g1Rows(gi1) = g1Rows(gi1) + 1
        If IsHO(rData(r,6)) Then
            g1HasHO(gi1) = True
            g1HOQty(gi1) = g1HOQty(gi1) + Abs(rRawQty(r))
        Else
            g1HasDK(gi1) = True
            g1DKQty(gi1) = g1DKQty(gi1) + Abs(rRawQty(r))
        End If
        g1Mem(gi1) = IIf(g1Mem(gi1)="", CStr(r), g1Mem(gi1) & "|" & CStr(r))
        If rData(r,13)<>"" And InStr(g1Sec(gi1),rData(r,13))=0 Then
            g1Sec(gi1) = IIf(g1Sec(gi1)="", rData(r,13), g1Sec(gi1) & " | " & rData(r,13))
        End If
NextRP1:
    Next r

    ' Classify pass 1
    For g = 1 To gc1
        If g1Rows(g) < 2 Then GoTo SkipP1
        If Not g1HasHO(g) Or Not g1HasDK(g) Then GoTo SkipP1

        Dim qtyMatch1 As Boolean
        qtyMatch1 = (Abs(g1HOQty(g) - g1DKQty(g)) < 0.001)
        Dim netVal1 As Double : netVal1 = g1NetV(g)
        Dim netQty1 As Double : netQty1 = g1NetQ(g)
        Dim multiPx1 As Boolean : multiPx1 = (Abs(g1MaxPx(g)-g1MinPx(g)) > 0.00001)
        Dim multiSec1 As Boolean : multiSec1 = (InStr(g1Sec(g),"|")>0)
        Dim st1 As String : Dim n1 As String

        If qtyMatch1 Then
            If Abs(netVal1) < 0.01 Then
                st1 = "FALSE BREAK"
                n1 = "HO qty = DK qty, net value = 0. Fully cancels."
                If multiPx1 Then n1 = n1 & " | Prices: " & g1PxList(g)
                If multiSec1 Then n1 = n1 & " | CUST/HOUSE: " & g1Sec(g)
            ElseIf Abs(netVal1) <= APS_THRESHOLD Then
                st1 = "APS ROUNDING"
                n1 = "HO qty = DK qty. Value diff " & Format(netVal1,"+#,##0.00;-#,##0.00") & " within $20 APS rounding."
            Else
                st1 = "PRICE BREAK"
                n1 = "HO qty = DK qty but cash does not net: " & Format(netVal1,"+#,##0.00;-#,##0.00") & "."
                If multiPx1 Then
                    n1 = n1 & " Price range: " & Format(g1MinPx(g),"0.0000") & " - " & Format(g1MaxPx(g),"0.0000") & "."
                End If
            End If

            If oc >= MAXG Then GoTo SkipP1
            oc = oc + 1
            oLabel(oc)=st1:oNote(oc)=n1:oGMI(oc)=g1GMI(g):oProd(oc)=g1Prod(g)
            oDates(oc)=g1Date(g):oPrice(oc)=g1MinPx(g):oNetQty(oc)=netQty1
            oNetVal(oc)=netVal1:oMembers(oc)=g1Mem(g):oSec(oc)=g1Sec(g)
            Call CountStat(st1,cFB,cAPS,cPB,cTB,cSS)

            Dim pts1() As String : pts1 = Split(g1Mem(g), "|")
            Dim p As Long
            For p = 0 To UBound(pts1)
                If pts1(p)<>"" Then rResolved(CLng(pts1(p))) = True
            Next p
            g1Mem(g) = ""

        Else
            ' ── MIXED GROUP: try greedy subset matching ───────────
            ' Separate into HO and DK arrays
            Dim hoIdx(500) As Long, hoCount As Long : hoCount = 0
            Dim dkIdx(500) As Long, dkCount As Long : dkCount = 0
            Dim mPts() As String : mPts = Split(g1Mem(g), "|")
            Dim mp As Long
            For mp = 0 To UBound(mPts)
                If Trim(mPts(mp)) = "" Then GoTo NextMP
                Dim mR As Long : mR = CLng(Trim(mPts(mp)))
                If IsHO(rData(mR,6)) Then
                    hoCount = hoCount + 1
                    hoIdx(hoCount) = mR
                Else
                    dkCount = dkCount + 1
                    dkIdx(dkCount) = mR
                End If
NextMP:
            Next mp

            ' Sort HO by abs qty descending (bubble sort)
            Dim si As Long, sj As Long, stmp As Long
            For si = 1 To hoCount - 1
                For sj = 1 To hoCount - si
                    If Abs(rRawQty(hoIdx(sj))) < Abs(rRawQty(hoIdx(sj+1))) Then
                        stmp = hoIdx(sj) : hoIdx(sj) = hoIdx(sj+1) : hoIdx(sj+1) = stmp
                    End If
                Next sj
            Next si

            ' Sort DK by abs qty descending
            For si = 1 To dkCount - 1
                For sj = 1 To dkCount - si
                    If Abs(rRawQty(dkIdx(sj))) < Abs(rRawQty(dkIdx(sj+1))) Then
                        stmp = dkIdx(sj) : dkIdx(sj) = dkIdx(sj+1) : dkIdx(sj+1) = stmp
                    End If
                Next sj
            Next si

            ' Greedy matching: for each HO, find DK subset with matching qty AND value=0
            Dim hoUsed(500) As Boolean
            Dim dkUsed(500) As Boolean
            Dim hi As Long, di As Long

            For hi = 1 To hoCount
                If hoUsed(hi) Then GoTo NextHI
                Dim hoAbsQ As Double : hoAbsQ = Abs(rRawQty(hoIdx(hi)))
                Dim hoAbsV As Double : hoAbsV = rRawVal(hoIdx(hi))

                Dim dkSumQ As Double : dkSumQ = 0
                Dim dkSumV As Double : dkSumV = 0
                Dim matchMem As String : matchMem = ""
                Dim dkTmpUsed(500) As Boolean

                ' Accumulate DK rows up to the HO qty target
                For di = 1 To dkCount
                    If dkUsed(di) Then GoTo NextDI
                    If dkSumQ >= hoAbsQ - 0.001 Then GoTo NextDI
                    dkSumQ = dkSumQ + Abs(rRawQty(dkIdx(di)))
                    dkSumV = dkSumV + rRawVal(dkIdx(di))
                    matchMem = IIf(matchMem="", CStr(dkIdx(di)), matchMem & "|" & CStr(dkIdx(di)))
                    dkTmpUsed(di) = True
NextDI:
                Next di

                ' Check qty matches and value exactly nets to zero
                If Abs(dkSumQ - hoAbsQ) < 0.001 And Abs(hoAbsV - dkSumV) < 0.01 Then
                    ' Match — write as FALSE BREAK
                    If oc < MAXG Then
                        oc = oc + 1
                        oLabel(oc) = "FALSE BREAK"
                        oNote(oc)  = "Net qty = 0, net value = 0. Matched within mixed group."
                        If multiSec1 Then oNote(oc) = oNote(oc) & " | CUST/HOUSE: " & g1Sec(g)
                        oGMI(oc)   = g1GMI(g) : oProd(oc) = g1Prod(g) : oDates(oc) = g1Date(g)
                        oPrice(oc) = g1MinPx(g) : oNetQty(oc) = 0 : oNetVal(oc) = 0
                        oSec(oc)   = g1Sec(g)
                        oMembers(oc) = CStr(hoIdx(hi)) & "|" & matchMem
                        cFB = cFB + 1
                        hoUsed(hi) = True
                        rResolved(hoIdx(hi)) = True
                        rMatched(hoIdx(hi)) = True
                        For di = 1 To dkCount
                            If dkTmpUsed(di) Then
                                dkUsed(di) = True
                                rResolved(dkIdx(di)) = True
                                rMatched(dkIdx(di)) = True
                            End If
                        Next di
                    End If
                End If
NextHI:
            Next hi

            ' Remaining unmatched rows in this group → TRUE BREAK
            Dim remMem As String : remMem = ""
            Dim remNetQ As Double : remNetQ = 0
            Dim remNetV As Double : remNetV = 0
            Dim remHasHO As Boolean : remHasHO = False
            Dim remHasDK As Boolean : remHasDK = False

            For hi = 1 To hoCount
                If Not hoUsed(hi) Then
                    remMem = IIf(remMem="", CStr(hoIdx(hi)), remMem & "|" & CStr(hoIdx(hi)))
                    remNetQ = remNetQ + rEffQty(hoIdx(hi))
                    remNetV = remNetV + rEffVal(hoIdx(hi))
                    remHasHO = True
                End If
            Next hi
            For di = 1 To dkCount
                If Not dkUsed(di) Then
                    remMem = IIf(remMem="", CStr(dkIdx(di)), remMem & "|" & CStr(dkIdx(di)))
                    remNetQ = remNetQ + rEffQty(dkIdx(di))
                    remNetV = remNetV + rEffVal(dkIdx(di))
                    remHasDK = True
                End If
            Next di

            If remMem <> "" Then
                ' Check if remainder nets to zero (could be a price break)
                Dim remSt As String : Dim remN As String
                If Abs(remNetQ) < 0.001 Then
                    If Abs(remNetV) < 0.01 Then
                        remSt = "FALSE BREAK"
                        remN = "Remaining rows net to zero after sub-group matching."
                    ElseIf Abs(remNetV) <= APS_THRESHOLD Then
                        remSt = "APS ROUNDING"
                        remN = "Remaining rows: qty=0, value diff " & Format(remNetV,"+#,##0.00;-#,##0.00") & " APS rounding."
                    Else
                        remSt = "PRICE BREAK"
                        remN = "Remaining rows: qty=0 but cash does not net: " & Format(remNetV,"+#,##0.00;-#,##0.00") & "."
                    End If
                Else
                    remSt = "TRUE BREAK"
                    remN = "Open qty: " & Format(remNetQ,"+0.###;-0.###")
                    If Abs(remNetV) >= 0.01 Then remN = remN & " | Net value: " & Format(remNetV,"+#,##0.00;-#,##0.00")
                    If Not remHasHO Then remN = remN & " | No H/O side."
                    If Not remHasDK Then remN = remN & " | No DK side."
                End If

                If oc < MAXG Then
                    oc = oc + 1
                    oLabel(oc)=remSt:oNote(oc)=remN:oGMI(oc)=g1GMI(g):oProd(oc)=g1Prod(g)
                    oDates(oc)=g1Date(g):oPrice(oc)=g1MinPx(g):oNetQty(oc)=remNetQ
                    oNetVal(oc)=remNetV:oMembers(oc)=remMem:oSec(oc)=g1Sec(g)
                    Call CountStat(remSt,cFB,cAPS,cPB,cTB,cSS)
                End If

                ' Mark remainder as resolved (handled by true/price break output)
                Dim rPts() As String : rPts = Split(remMem, "|")
                For p = 0 To UBound(rPts)
                    If rPts(p)<>"" Then rResolved(CLng(rPts(p))) = True
                Next p
            End If

            g1Mem(g) = ""
        End If
SkipP1:
    Next g

    ' ════════════════════════════════════════════════════════════
    ' PASS 2 — GMI + Product + IntPrice (multi-date)
    ' ════════════════════════════════════════════════════════════
    Const MAXG2 As Long = 3000
    Dim g2Key(MAXG2)    As String
    Dim g2GMI(MAXG2)    As String
    Dim g2Prod(MAXG2)   As String
    Dim g2Price(MAXG2)  As Double
    Dim g2NetQ(MAXG2)   As Double
    Dim g2NetV(MAXG2)   As Double
    Dim g2HOQty(MAXG2)  As Double
    Dim g2DKQty(MAXG2)  As Double
    Dim g2Rows(MAXG2)   As Long
    Dim g2HasHO(MAXG2)  As Boolean
    Dim g2HasDK(MAXG2)  As Boolean
    Dim g2Mem(MAXG2)    As String
    Dim g2Sec(MAXG2)    As String
    Dim g2Dates(MAXG2)  As String
    Dim gc2 As Long : gc2 = 0

    For r = 1 To rc
        If rResolved(r) Then GoTo NextRP2
        Dim k2 As String
        k2 = rData(r,1) & "||" & rData(r,4) & "||" & rIntPxKey(r)
        Dim gi2 As Long : gi2 = 0
        For g = 1 To gc2
            If g2Key(g) = k2 Then gi2 = g : Exit For
        Next g
        If gi2 = 0 Then
            If gc2 >= MAXG2 Then GoTo NextRP2
            gc2 = gc2 + 1 : gi2 = gc2
            g2Key(gi2)   = k2 : g2GMI(gi2) = rData(r,1)
            g2Prod(gi2)  = rData(r,4) : g2Price(gi2) = SafeDbl(rData(r,5))
            g2NetQ(gi2)  = 0 : g2NetV(gi2) = 0 : g2Rows(gi2) = 0
            g2HOQty(gi2) = 0 : g2DKQty(gi2) = 0
            g2HasHO(gi2) = False : g2HasDK(gi2) = False
            g2Mem(gi2)   = "" : g2Sec(gi2) = "" : g2Dates(gi2) = ""
        End If
        g2NetQ(gi2) = g2NetQ(gi2) + rEffQty(r)
        g2NetV(gi2) = g2NetV(gi2) + rEffVal(r)
        g2Rows(gi2) = g2Rows(gi2) + 1
        If IsHO(rData(r,6)) Then
            g2HasHO(gi2) = True
            g2HOQty(gi2) = g2HOQty(gi2) + Abs(rRawQty(r))
        Else
            g2HasDK(gi2) = True
            g2DKQty(gi2) = g2DKQty(gi2) + Abs(rRawQty(r))
        End If
        g2Mem(gi2) = IIf(g2Mem(gi2)="", CStr(r), g2Mem(gi2) & "|" & CStr(r))
        If rData(r,2)<>"" And InStr(g2Dates(gi2),rData(r,2))=0 Then
            g2Dates(gi2) = IIf(g2Dates(gi2)="", rData(r,2), g2Dates(gi2) & ", " & rData(r,2))
        End If
        If rData(r,13)<>"" And InStr(g2Sec(gi2),rData(r,13))=0 Then
            g2Sec(gi2) = IIf(g2Sec(gi2)="", rData(r,13), g2Sec(gi2) & " | " & rData(r,13))
        End If
NextRP2:
    Next r

    For g = 1 To gc2
        If g2Rows(g) < 2 Then GoTo SkipP2
        If Not g2HasHO(g) Or Not g2HasDK(g) Then GoTo SkipP2
        Dim qtyMatch2 As Boolean
        qtyMatch2 = (Abs(g2HOQty(g) - g2DKQty(g)) < 0.001)
        Dim netVal2 As Double : netVal2 = g2NetV(g)
        Dim multiSec2 As Boolean : multiSec2 = (InStr(g2Sec(g),"|")>0)
        Dim st2 As String : Dim n2 As String

        If qtyMatch2 Then
            If Abs(netVal2) < 0.01 Then
                st2 = "FALSE BREAK"
                n2 = "HO qty = DK qty, net value = 0. Multi-date / T+2. Dates: " & g2Dates(g)
                If multiSec2 Then n2 = n2 & " | CUST/HOUSE: " & g2Sec(g)
            ElseIf Abs(netVal2) <= APS_THRESHOLD Then
                st2 = "APS ROUNDING"
                n2 = "HO qty = DK qty. Value diff " & Format(netVal2,"+#,##0.00;-#,##0.00") & " within $20. Dates: " & g2Dates(g)
            Else
                st2 = "PRICE BREAK"
                n2 = "HO qty = DK qty but cash does not net: " & Format(netVal2,"+#,##0.00;-#,##0.00") & ". Dates: " & g2Dates(g)
            End If
        Else
            st2 = "TRUE BREAK"
            n2 = "Open qty: " & Format(g2NetQ(g),"+0.###;-0.###")
            If Abs(netVal2) >= 0.01 Then n2 = n2 & " | Net value: " & Format(netVal2,"+#,##0.00;-#,##0.00")
            If Not g2HasHO(g) Then n2 = n2 & " | No H/O side."
            If Not g2HasDK(g) Then n2 = n2 & " | No DK side."
            n2 = n2 & " | Dates: " & g2Dates(g)
        End If

        If oc >= MAXG Then GoTo SkipP2
        oc = oc + 1
        oLabel(oc)=st2:oNote(oc)=n2:oGMI(oc)=g2GMI(g):oProd(oc)=g2Prod(g)
        oDates(oc)=g2Dates(g):oPrice(oc)=g2Price(g):oNetQty(oc)=g2NetQ(g)
        oNetVal(oc)=netVal2:oMembers(oc)=g2Mem(g):oSec(oc)=g2Sec(g)
        Call CountStat(st2,cFB,cAPS,cPB,cTB,cSS)

        Dim pts2() As String : pts2 = Split(g2Mem(g), "|")
        Dim p2 As Long
        For p2 = 0 To UBound(pts2)
            If pts2(p2)<>"" Then rResolved(CLng(pts2(p2))) = True
        Next p2
        g2Mem(g) = ""
SkipP2:
    Next g

    ' ════════════════════════════════════════════════════════════
    ' PASS 3 — Product + IntPrice (cross-GMI / cross-section)
    ' ════════════════════════════════════════════════════════════
    Const MAXG3 As Long = 3000
    Dim g3Key(MAXG3)    As String
    Dim g3GMIs(MAXG3)   As String
    Dim g3Prod(MAXG3)   As String
    Dim g3Price(MAXG3)  As Double
    Dim g3NetQ(MAXG3)   As Double
    Dim g3NetV(MAXG3)   As Double
    Dim g3HOQty(MAXG3)  As Double
    Dim g3DKQty(MAXG3)  As Double
    Dim g3Rows(MAXG3)   As Long
    Dim g3HasHO(MAXG3)  As Boolean
    Dim g3HasDK(MAXG3)  As Boolean
    Dim g3Mem(MAXG3)    As String
    Dim g3Sec(MAXG3)    As String
    Dim g3Dates(MAXG3)  As String
    Dim gc3 As Long : gc3 = 0

    For r = 1 To rc
        If rResolved(r) Then GoTo NextRP3
        Dim k3 As String
        k3 = rData(r,4) & "||" & rIntPxKey(r)
        Dim gi3 As Long : gi3 = 0
        For g = 1 To gc3
            If g3Key(g) = k3 Then gi3 = g : Exit For
        Next g
        If gi3 = 0 Then
            If gc3 >= MAXG3 Then GoTo NextRP3
            gc3 = gc3 + 1 : gi3 = gc3
            g3Key(gi3)   = k3 : g3GMIs(gi3) = ""
            g3Prod(gi3)  = rData(r,4) : g3Price(gi3) = SafeDbl(rData(r,5))
            g3NetQ(gi3)  = 0 : g3NetV(gi3) = 0 : g3Rows(gi3) = 0
            g3HOQty(gi3) = 0 : g3DKQty(gi3) = 0
            g3HasHO(gi3) = False : g3HasDK(gi3) = False
            g3Mem(gi3)   = "" : g3Sec(gi3) = "" : g3Dates(gi3) = ""
        End If
        g3NetQ(gi3) = g3NetQ(gi3) + rEffQty(r)
        g3NetV(gi3) = g3NetV(gi3) + rEffVal(r)
        g3Rows(gi3) = g3Rows(gi3) + 1
        If IsHO(rData(r,6)) Then
            g3HasHO(gi3) = True
            g3HOQty(gi3) = g3HOQty(gi3) + Abs(rRawQty(r))
        Else
            g3HasDK(gi3) = True
            g3DKQty(gi3) = g3DKQty(gi3) + Abs(rRawQty(r))
        End If
        g3Mem(gi3) = IIf(g3Mem(gi3)="", CStr(r), g3Mem(gi3) & "|" & CStr(r))
        If rData(r,1)<>"" And InStr(g3GMIs(gi3),rData(r,1))=0 Then
            g3GMIs(gi3) = IIf(g3GMIs(gi3)="", rData(r,1), g3GMIs(gi3) & ", " & rData(r,1))
        End If
        If rData(r,2)<>"" And InStr(g3Dates(gi3),rData(r,2))=0 Then
            g3Dates(gi3) = IIf(g3Dates(gi3)="", rData(r,2), g3Dates(gi3) & ", " & rData(r,2))
        End If
        If rData(r,13)<>"" And InStr(g3Sec(gi3),rData(r,13))=0 Then
            g3Sec(gi3) = IIf(g3Sec(gi3)="", rData(r,13), g3Sec(gi3) & " | " & rData(r,13))
        End If
NextRP3:
    Next r

    For g = 1 To gc3
        If g3Rows(g) < 2 Then GoTo SkipP3
        If Not g3HasHO(g) Or Not g3HasDK(g) Then GoTo SkipP3
        Dim qtyMatch3 As Boolean
        qtyMatch3 = (Abs(g3HOQty(g) - g3DKQty(g)) < 0.001)
        Dim netVal3 As Double : netVal3 = g3NetV(g)
        Dim multiSec3 As Boolean : multiSec3 = (InStr(g3Sec(g),"|")>0)
        Dim crossGMI3 As Boolean : crossGMI3 = (InStr(g3GMIs(g),",")>0)
        Dim st3 As String : Dim n3 As String

        If qtyMatch3 Then
            If Abs(netVal3) < 0.01 Then
                st3 = "FALSE BREAK"
                n3 = "HO qty = DK qty, net value = 0."
                If multiSec3 Or crossGMI3 Then n3 = n3 & " CUST/HOUSE transfer: " & g3Sec(g)
                If InStr(g3Dates(g),",")>0 Then n3 = n3 & " Dates: " & g3Dates(g)
            ElseIf Abs(netVal3) <= APS_THRESHOLD Then
                st3 = "APS ROUNDING"
                n3 = "HO qty = DK qty. Value diff " & Format(netVal3,"+#,##0.00;-#,##0.00") & " within $20."
                If multiSec3 Then n3 = n3 & " Transfer: " & g3Sec(g)
            Else
                st3 = "PRICE BREAK"
                n3 = "HO qty = DK qty but cash does not net: " & Format(netVal3,"+#,##0.00;-#,##0.00") & "."
            End If
        Else
            st3 = "TRUE BREAK"
            n3 = "Open qty: " & Format(g3NetQ(g),"+0.###;-0.###")
            If Abs(netVal3) >= 0.01 Then n3 = n3 & " | Net value: " & Format(netVal3,"+#,##0.00;-#,##0.00")
            If multiSec3 Or crossGMI3 Then n3 = n3 & " | Cross-section: " & g3Sec(g)
        End If

        If oc >= MAXG Then GoTo SkipP3
        oc = oc + 1
        oLabel(oc)=st3:oNote(oc)=n3:oGMI(oc)=g3GMIs(g):oProd(oc)=g3Prod(g)
        oDates(oc)=g3Dates(g):oPrice(oc)=g3Price(g):oNetQty(oc)=g3NetQ(g)
        oNetVal(oc)=netVal3:oMembers(oc)=g3Mem(g):oSec(oc)=g3Sec(g)
        Call CountStat(st3,cFB,cAPS,cPB,cTB,cSS)

        Dim pts3() As String : pts3 = Split(g3Mem(g), "|")
        Dim p3 As Long
        For p3 = 0 To UBound(pts3)
            If pts3(p3)<>"" Then rResolved(CLng(pts3(p3))) = True
        Next p3
        g3Mem(g) = ""
SkipP3:
    Next g

    ' ════════════════════════════════════════════════════════════
    ' PASS 4 — Remaining = TRUE BREAK or SINGLE-SIDED
    ' ════════════════════════════════════════════════════════════
    Const MAXG4 As Long = 3000
    Dim g4Key(MAXG4)   As String
    Dim g4GMI(MAXG4)   As String
    Dim g4Prod(MAXG4)  As String
    Dim g4Price(MAXG4) As Double
    Dim g4NetQ(MAXG4)  As Double
    Dim g4NetV(MAXG4)  As Double
    Dim g4Rows(MAXG4)  As Long
    Dim g4HasHO(MAXG4) As Boolean
    Dim g4HasDK(MAXG4) As Boolean
    Dim g4Mem(MAXG4)   As String
    Dim g4Sec(MAXG4)   As String
    Dim g4Dates(MAXG4) As String
    Dim gc4 As Long : gc4 = 0

    For r = 1 To rc
        If rResolved(r) Then GoTo NextRP4
        Dim k4 As String
        k4 = rData(r,1) & "||" & rData(r,4) & "||" & rIntPxKey(r)
        Dim gi4 As Long : gi4 = 0
        For g = 1 To gc4
            If g4Key(g) = k4 Then gi4 = g : Exit For
        Next g
        If gi4 = 0 Then
            If gc4 >= MAXG4 Then GoTo NextRP4
            gc4 = gc4 + 1 : gi4 = gc4
            g4Key(gi4)   = k4 : g4GMI(gi4) = rData(r,1)
            g4Prod(gi4)  = rData(r,4) : g4Price(gi4) = SafeDbl(rData(r,5))
            g4NetQ(gi4)  = 0 : g4NetV(gi4) = 0 : g4Rows(gi4) = 0
            g4HasHO(gi4) = False : g4HasDK(gi4) = False
            g4Mem(gi4)   = "" : g4Sec(gi4) = "" : g4Dates(gi4) = ""
        End If
        g4NetQ(gi4) = g4NetQ(gi4) + rEffQty(r)
        g4NetV(gi4) = g4NetV(gi4) + rEffVal(r)
        g4Rows(gi4) = g4Rows(gi4) + 1
        If IsHO(rData(r,6)) Then g4HasHO(gi4) = True Else g4HasDK(gi4) = True
        g4Mem(gi4) = IIf(g4Mem(gi4)="", CStr(r), g4Mem(gi4) & "|" & CStr(r))
        If rData(r,2)<>"" And InStr(g4Dates(gi4),rData(r,2))=0 Then
            g4Dates(gi4) = IIf(g4Dates(gi4)="", rData(r,2), g4Dates(gi4) & ", " & rData(r,2))
        End If
        If rData(r,13)<>"" And InStr(g4Sec(gi4),rData(r,13))=0 Then
            g4Sec(gi4) = IIf(g4Sec(gi4)="", rData(r,13), g4Sec(gi4) & " | " & rData(r,13))
        End If
NextRP4:
    Next r

    For g = 1 To gc4
        If oc >= MAXG Then GoTo SkipP4
        oc = oc + 1
        Dim st4 As String : Dim n4 As String
        st4 = IIf(g4Rows(g) = 1, "SINGLE-SIDED", "TRUE BREAK")
        If st4 = "TRUE BREAK" Then
            n4 = "Open qty: " & Format(g4NetQ(g),"+0.###;-0.###")
            If Abs(g4NetV(g)) >= 0.01 Then
                n4 = n4 & " | Net value: " & Format(g4NetV(g),"+#,##0.00;-#,##0.00")
            End If
            If Not g4HasHO(g) Then n4 = n4 & " | No H/O cancel side."
            If Not g4HasDK(g) Then n4 = n4 & " | No DK add side."
            If InStr(g4Dates(g),",")>0 Then n4 = n4 & " | Dates: " & g4Dates(g)
        Else
            n4 = "Single row — nothing to net against."
        End If
        oLabel(oc)=st4:oNote(oc)=n4:oGMI(oc)=g4GMI(g):oProd(oc)=g4Prod(g)
        oDates(oc)=g4Dates(g):oPrice(oc)=g4Price(g):oNetQty(oc)=g4NetQ(g)
        oNetVal(oc)=g4NetV(g):oMembers(oc)=g4Mem(g):oSec(oc)=g4Sec(g)
        Call CountStat(st4,cFB,cAPS,cPB,cTB,cSS)
SkipP4:
    Next g

    ' ════════════════════════════════════════════════════════════
    ' WRITE OUTPUT
    ' ════════════════════════════════════════════════════════════
    With wsOut
        If .AutoFilterMode Then .AutoFilterMode = False
        .Range("A7:N3000").ClearContents
        .Range("A7:N3000").Interior.ColorIndex = xlNone
        .Range("A7:N3000").Borders.LineStyle = xlNone
    End With

    Dim outR As Long : outR = 7

    Dim sortOrder(5) As String
    sortOrder(1)="FALSE BREAK":sortOrder(2)="APS ROUNDING"
    sortOrder(3)="PRICE BREAK":sortOrder(4)="TRUE BREAK":sortOrder(5)="SINGLE-SIDED"

    Dim so As Long
    For so = 1 To 5
        Dim oi As Long
        For oi = 1 To oc
            If oLabel(oi)<>sortOrder(so) Then GoTo NextOI
            If oMembers(oi)="" Then GoTo NextOI
            Call WriteGroup(wsOut, outR, oLabel(oi), oNote(oi), _
                            oGMI(oi), oProd(oi), oDates(oi), oPrice(oi), _
                            oNetQty(oi), oNetVal(oi), oMembers(oi), oSec(oi), rData)
            oMembers(oi) = ""
NextOI:
        Next oi
    Next so

    ' ── Stats ────────────────────────────────────────────────────
    wsOut.Cells(4,1).Value  = "Total Rows:  " & rc
    wsOut.Cells(4,3).Value  = "Break Groups:  " & (cFB+cAPS+cPB+cTB+cSS)
    wsOut.Cells(4,5).Value  = "False Breaks:  " & cFB & IIf(cAPS>0," (+" & cAPS & " APS)","")
    wsOut.Cells(4,7).Value  = "Price Breaks:  " & cPB
    wsOut.Cells(4,9).Value  = "True Breaks:  " & cTB
    wsOut.Cells(4,11).Value = "Single-Sided:  " & cSS

    With wsOut.Cells(4,1):.Font.Bold=True:.Font.Size=10:.Font.Name="Calibri":.Font.Color=RGB(0,0,0):End With
    With wsOut.Cells(4,3):.Font.Bold=True:.Font.Size=10:.Font.Name="Calibri":.Font.Color=RGB(0,0,0):End With
    With wsOut.Cells(4,5):.Font.Bold=True:.Font.Size=10:.Font.Name="Calibri":.Font.Color=RGB(55,86,35):.Interior.Color=RGB(226,239,218):End With
    With wsOut.Cells(4,7):.Font.Bold=True:.Font.Size=10:.Font.Name="Calibri":.Font.Color=RGB(31,73,125):.Interior.Color=RGB(221,238,255):End With
    With wsOut.Cells(4,9):.Font.Bold=True:.Font.Size=10:.Font.Name="Calibri":.Font.Color=RGB(132,60,12):.Interior.Color=RGB(252,228,214):End With
    With wsOut.Cells(4,11):.Font.Bold=True:.Font.Size=10:.Font.Name="Calibri":.Font.Color=RGB(89,89,89):.Interior.Color=RGB(237,237,237):End With

    wsOut.Range("A6:N6").AutoFilter
    wsOut.Activate
    wsOut.Cells(7,1).Select

    MsgBox "Done!" & Chr(10) & Chr(10) & _
           rc & " rows processed" & Chr(10) & _
           "False Breaks:   " & cFB & Chr(10) & _
           "APS Rounding:   " & cAPS & Chr(10) & _
           "Price Breaks:   " & cPB & Chr(10) & _
           "True Breaks:    " & cTB & Chr(10) & _
           "Single-Sided:   " & cSS, vbInformation, "Recon Complete"

Cleanup:
    Application.ScreenUpdating = True
    Application.Calculation = xlCalculationAutomatic
End Sub

' ════════════════════════════════════════════════════════════════════
Public Sub ClearResults()
    Dim wsOut As Worksheet
    Set wsOut = ThisWorkbook.Sheets("RESULTS")
    With wsOut
        If .AutoFilterMode Then .AutoFilterMode = False
        .Range("A7:N3000").ClearContents
        .Range("A7:N3000").Interior.ColorIndex = xlNone
        .Range("A7:N3000").Borders.LineStyle = xlNone
    End With
    wsOut.Cells(4,1).Value="Total Rows:":wsOut.Cells(4,3).Value="Break Groups:"
    wsOut.Cells(4,5).Value="False Breaks:":wsOut.Cells(4,7).Value="Price Breaks:"
    wsOut.Cells(4,9).Value="True Breaks:":wsOut.Cells(4,11).Value="Single-Sided:"
    MsgBox "Results cleared.", vbInformation, "Cleared"
End Sub
