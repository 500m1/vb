Dim diagStr As String
diagStr = "gc1=" & gc1 & Chr(10)
Dim dg As Long
For dg = 1 To Application.Min(gc1, 5)
    diagStr = diagStr & "Key" & dg & ": [" & g1Key(dg) & "]" & Chr(10)
    diagStr = diagStr & "  Rows=" & g1Rows(dg) & " NetQ=" & g1NetQ(dg) & Chr(10)
Next dg
MsgBox diagStr, vbInformation, "Keys"
