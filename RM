        For p3 = 0 To UBound(pts3)
            If pts3(p3)<>"" Then rResolved(CLng(pts3(p3))) = True
        Next p3
        g3Mem(g) = ""
SkipP3:
    Next g

    ' ════════════════════════════════════════════════════════════
    ' PASS 4 — Remaining = TRUE BREAK or SINGLE-SIDED
    ' ════════════════════════════════════════════════════════════
    Const MAXG4 As Long = 3000
    Dim g4Key(MAXG4)   As String
    Dim g4GMI(MAXG4)   As String
    Dim g4Prod(MAXG4)  As String
    Dim g4Price(MAXG4) As Double
    Dim g4NetQ(MAXG4)  As Double
    Dim g4NetV(MAXG4)  As Double
    Dim g4Rows(MAXG4)  As Long
    Dim g4HasHO(MAXG4) As Boolean
    Dim g4HasDK(MAXG4) As Boolean
    Dim g4Mem(MAXG4)   As String
    Dim g4Sec(MAXG4)   As String
    Dim g4Dates(MAXG4) As String
    Dim gc4 As Long : gc4 = 0

    For r = 1 To rc
        If rResolved(r) Then GoTo NextRP4
        Dim k4 As String
        k4 = rData(r,1) & "||" & rData(r,4) & "||" & rIntPxKey(r)
        Dim gi4 As Long : gi4 = 0
        For g = 1 To gc4
