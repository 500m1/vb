            gc4 = gc4 + 1 : gi4 = gc4
            g4Key(gi4)   = k4 : g4GMI(gi4) = rData(r,1)
            g4Prod(gi4)  = rData(r,4) : g4Price(gi4) = SafeDbl(rData(r,5))
            g4NetQ(gi4)  = 0 : g4NetV(gi4) = 0 : g4Rows(gi4) = 0
            g4HasHO(gi4) = False : g4HasDK(gi4) = False
